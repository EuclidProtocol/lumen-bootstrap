# ──────────────────────────────────────────────────────────────
# Blockchain Node
# ──────────────────────────────────────────────────────────────

# Binary name used by docker-compose (lumend for mainnet, lumentestd for testnet)
BINARY="lumend"

# Chain identifier (lumen-1 for mainnet, lumen-test-1 for testnet)
CHAIN_ID="lumen-1"

# Token denominations
DENOM="ualpha"
STAKE_DENOM="usync"

# Validator configuration
VALIDATOR_MNEMONIC=""
NODE_IP=""
PEERS=""

# State sync configuration
PRIMARY_SNAP_RPC_IP=""
SNAP_RPCS=""

# ──────────────────────────────────────────────────────────────
# Snapshot CLI & Server
# ──────────────────────────────────────────────────────────────

# Tendermint RPC port on the local node (default: 26657)
RPC_PORT=26657

# Path to the chain data directory. When unset, resolved automatically
# from the chain ID (e.g. .config/lumen-1).
# CHAIN_HOME=.config/lumen-1

# Prefix shell commands with sudo (set to "true" on hosts where the
# current user lacks Docker or filesystem permissions).
# Affects make, tar, and lz4 commands.
ENABLE_SUDO=false

# Local directory for temporary snapshot archives (cleaned up after upload)
SNAPSHOT_DIR=./snapshots

# ──────────────────────────────────────────────────────────────
# S3-Compatible Object Storage
#
# Works with AWS S3, Hetzner Object Storage, MinIO, or any
# provider that implements the S3 API.
# ──────────────────────────────────────────────────────────────

# Custom endpoint URL for non-AWS providers. Leave unset for AWS S3.
# Examples:
#   Hetzner:  https://fsn1.your-objectstorage.com
#   MinIO:    http://localhost:9000
S3_ENDPOINT=

# Region identifier (e.g. "us-east-1" for AWS, "fsn1" for Hetzner)
S3_REGION=us-east-1

# Credentials
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Bucket name where snapshots are stored
S3_BUCKET=euclid-snapshots

# Set to "true" for non-AWS providers that use path-style URLs
# (bucket in path instead of subdomain). Required for Hetzner and MinIO.
S3_FORCE_PATH_STYLE=false

# Set to "true" if the bucket allows public read access. When enabled,
# the API returns direct public URLs instead of pre-signed URLs.
S3_PUBLIC_BUCKET=false

# How long pre-signed download URLs remain valid (in seconds, default: 3600).
# Ignored when S3_PUBLIC_BUCKET is true.
S3_PRESIGN_EXPIRY=3600


# ──────────────────────────────────────────────────────────────
# Edgenet
# ──────────────────────────────────────────────────────────────

SNAPSHOT_URL=https://snapshot.lumen.euclidprotocol.com/api/snapshots/latest/download